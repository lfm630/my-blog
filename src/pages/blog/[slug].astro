---
// [slug].astro — 文章详情页（动态路由）
// [slug] 是 Astro 的动态路由参数，匹配 URL 中的路径段
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// 告诉 Astro 有哪些路径需要预渲染
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id }, // post.id 就是文件名去掉扩展名的部分
    props: { post },
  }));
}

// 接收 getStaticPaths 传入的 post 对象
const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} — 我的博客`}
  description={post.data.description}
>
  <article>
    <!-- 文章头部信息 -->
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">
        {post.data.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toISOString().slice(0, 10)}
        </time>

        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <!-- 文章正文 — 使用 .prose 类获得排版样式 -->
    <div class="prose">
      <Content />
    </div>
  </article>

  <!-- 返回链接 -->
  <footer class="mt-12 pt-6 border-t border-gray-200">
    <a href="/" class="text-sm text-blue-600 hover:text-blue-800 transition-colors">
      &larr; 回到首页
    </a>
  </footer>
</BaseLayout>
