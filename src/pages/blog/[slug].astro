---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { SITE } from "../../consts";

const base = SITE.base;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} — 我的博客`}
  description={post.data.description}
>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">
        {post.data.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toISOString().slice(0, 10)}
        </time>

        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <a
                  href={`${base}/tags/${encodeURIComponent(tag)}`}
                  class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full hover:bg-blue-100 hover:text-blue-700 transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  <footer class="mt-12 pt-6 border-t border-gray-200">
    <a href={base || "/"} class="text-sm text-blue-600 hover:text-blue-800 transition-colors">
      &larr; 回到首页
    </a>
  </footer>
</BaseLayout>
