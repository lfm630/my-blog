---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { SITE } from "../../consts";

const base = SITE.base;

const allPosts = (await getCollection("blog")).filter(
  (post) => !post.data.draft
);

const tagCount = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="标签 — 我的博客"
  description="按标签浏览所有文章。"
>
  <div class="mb-10">
    <h1 class="text-lg font-black font-mono mb-2 transition-colors duration-300" style="color: var(--color-text);">
      <span style="color: var(--color-accent);">##</span> Tags
    </h1>
    <p class="text-xs font-mono transition-colors duration-300" style="color: var(--color-text-muted);">
      <span style="color: var(--color-text-muted); opacity: 0.6;">//</span> <span style="color: var(--color-accent);">{tags.length}</span> tags · <span style="color: var(--color-accent);">{allPosts.length}</span> posts
    </p>
  </div>

  {
    tags.length === 0 ? (
      <div class="p-12 text-center text-sm font-mono" style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-muted);">
        <span style="opacity: 0.6;">//</span> no tags found
      </div>
    ) : (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {tags.map(([tag, count]) => (
          <a
            href={`${base}/tags/${encodeURIComponent(tag)}/`}
            class="group flex flex-col items-center p-6 glow-hover transition-all duration-300 text-center"
            style="
              background: var(--color-surface);
              border: 1px solid var(--color-border);
              clip-path: polygon(0 6px, 3px 3px, 6px 0, calc(100% - 6px) 0, calc(100% - 3px) 3px, 100% 6px, 100% calc(100% - 6px), calc(100% - 3px) calc(100% - 3px), calc(100% - 6px) 100%, 6px 100%, 3px calc(100% - 3px), 0 calc(100% - 6px));
            "
          >
            <span style="color: var(--color-accent); font-size: 20px; margin-bottom: 8px; font-family: monospace;">#</span>
            <span class="font-semibold font-mono transition-colors duration-300" style="color: var(--color-text);">
              {tag}
            </span>
            <span class="text-xs mt-1 font-mono transition-colors duration-300" style="color: var(--color-text-muted);">
              <span style="opacity: 0.6;">//</span> {count} post{count > 1 ? "s" : ""}
            </span>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
