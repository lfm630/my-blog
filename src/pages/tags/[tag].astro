---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";
import { SITE } from "../../consts";

const base = SITE.base;

export async function getStaticPaths() {
  const allPosts = (await getCollection("blog")).filter(
    (post) => !post.data.draft
  );
  const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))];
  return allTags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.tags.includes(tag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title={`标签：${tag} — 我的博客`}
  description={`包含标签"${tag}"的文章列表。`}
>
  <div class="mb-8">
    <a
      href={`${base}/tags/`}
      class="inline-flex items-center gap-1 text-xs font-mono transition-colors duration-300 mb-3" style="color: var(--color-text-muted);"
    >
      <span style="opacity: 0.6;">//</span> cd ../tags
    </a>
    <h1 class="text-lg font-black font-mono transition-colors duration-300" style="color: var(--color-text);">
      <span style="color: var(--color-accent);">##</span> # {tag}
    </h1>
    <p class="text-xs mt-1 font-mono transition-colors duration-300" style="color: var(--color-text-muted);">
      <span style="color: var(--color-text-muted); opacity: 0.6;">//</span> <span style="color: var(--color-accent);">{posts.length}</span> post{posts.length !== 1 ? "s" : ""} found
    </p>
  </div>

  {
    posts.length === 0 ? (
      <div class="p-12 text-center text-sm font-mono" style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-muted);">
        <span style="opacity: 0.6;">//</span> no posts found
      </div>
    ) : (
      <div class="space-y-4">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString().slice(0, 10)}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </div>
    )
  }
</BaseLayout>
