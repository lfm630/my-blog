---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";
import { SITE } from "../consts";

const base = SITE.base;

const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagCount = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="我的博客"
  description="一个分享技术、阅读与生活的个人博客。"
>
  <!-- ============================================================
       HERO — WHO THE HELL AM I
       ============================================================ -->
  <section class="mb-20">
    <!-- 左右两栏: 左头像 | 右文字 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
      <!-- 左半边: 头像 + 社交 -->
      <div class="flex flex-col items-center gap-5 order-2 md:order-1">
        <div class="avatar-container">
          <img
            src={`${base}/avatar.jpeg`}
            alt="avatar"
            class="avatar-img pixelated"
            style="
              width: 50vw; height: 50vw; max-width: 340px; max-height: 340px; min-width: 140px; min-height: 140px;
              object-fit: cover;
              filter: contrast(1.15) saturate(1.3) brightness(0.95);
              border: 2px solid var(--color-accent);
              box-shadow: 0 0 0 2px var(--color-bg), 0 0 0 5px var(--color-accent), 0 0 16px var(--color-accent-glow);
              clip-path: polygon(
                0 12px, 4px 8px, 8px 4px, 12px 0,
                calc(100% - 12px) 0, calc(100% - 8px) 4px, calc(100% - 4px) 8px, 100% 12px,
                100% calc(100% - 12px), calc(100% - 4px) calc(100% - 8px),
                calc(100% - 8px) calc(100% - 4px), calc(100% - 12px) 100%,
                12px 100%, 8px calc(100% - 4px), 4px calc(100% - 8px), 0 calc(100% - 12px)
              );
              transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                          box-shadow 0.5s ease,
                          filter 0.5s ease;
            "
          />
        </div>

        <div class="flex items-center justify-center gap-4">
          <a href="https://github.com/lfm630" target="_blank" rel="noopener noreferrer" title="GitHub"
             style="color: var(--color-text); transition: transform 0.2s ease, filter 0.2s ease;"
             onmouseenter="this.style.transform='scale(1.2)';this.style.filter='drop-shadow(0 0 6px var(--color-accent-glow))'"
             onmouseleave="this.style.transform='scale(1)';this.style.filter='none'">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
          </a>
          <a href="https://space.bilibili.com/695799967" target="_blank" rel="noopener noreferrer" title="Bilibili"
             style="color: #fb7299; transition: transform 0.2s ease, filter 0.2s ease;"
             onmouseenter="this.style.transform='scale(1.2)';this.style.filter='drop-shadow(0 0 6px #fb729966)'"
             onmouseleave="this.style.transform='scale(1)';this.style.filter='none'">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 01-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 01.16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373Z"/></svg>
          </a>
          <a href="https://t.me/nowredmoon" target="_blank" rel="noopener noreferrer" title="Telegram"
             style="color: #38bdf8; transition: transform 0.2s ease, filter 0.2s ease;"
             onmouseenter="this.style.transform='scale(1.2)';this.style.filter='drop-shadow(0 0 6px #38bdf866)'"
             onmouseleave="this.style.transform='scale(1)';this.style.filter='none'">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.561 8.161l-1.871 8.826c-.14.627-.513.783-1.04.487l-2.873-2.117-1.387 1.334c-.153.153-.28.28-.576.28l.205-2.906 5.291-4.781c.23-.205-.05-.32-.36-.116L8.953 13.24l-2.848-.89c-.62-.194-.632-.62.13-.92l11.136-4.29c.517-.194.97.126.807.92z"/></svg>
          </a>
          <a href="https://qm.qq.com/q/p124TlRFII" target="_blank" rel="noopener noreferrer" title="QQ"
             style="color: #3b82f6; transition: transform 0.2s ease, filter 0.2s ease;"
             onmouseenter="this.style.transform='scale(1.2)';this.style.filter='drop-shadow(0 0 6px #3b82f666)'"
             onmouseleave="this.style.transform='scale(1)';this.style.filter='none'">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M21.395 15.035a40 40 0 00-.803-2.264l-1.079-2.695c.001-.032.014-.562.014-.836C19.526 4.632 17.351 0 12 0S4.474 4.632 4.474 9.241c0 .274.013.804.014.836l-1.08 2.695a39 39 0 00-.802 2.264c-1.021 3.283-.69 4.643-.438 4.673.54.065 2.103-2.472 2.103-2.472 0 1.469.756 3.387 2.394 4.771-.612.188-1.363.479-1.845.835-.434.32-.379.646-.301.778.343.578 5.883.369 7.482.189 1.6.18 7.14.389 7.483-.189.078-.132.132-.458-.301-.778-.483-.356-1.233-.646-1.846-.836 1.637-1.384 2.393-3.302 2.393-4.771 0 0 1.563 2.537 2.103 2.472.251-.03.581-1.39-.438-4.673"/></svg>
          </a>
          <a href={`${base}/rss.xml`} title="RSS"
             style="color: #f97316; transition: transform 0.2s ease, filter 0.2s ease;"
             onmouseenter="this.style.transform='scale(1.2)';this.style.filter='drop-shadow(0 0 6px #f9731666)'"
             onmouseleave="this.style.transform='scale(1)';this.style.filter='none'">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66A9.9 9.9 0 0113.9 20h-2.83A7.07 7.07 0 004 12.93v-2.83z"/></svg>
          </a>
        </div>
      </div>

      <!-- 右半边: 像素条 + 标题 + 终端 -->
      <div class="order-1 md:order-2">
        <!-- █ 像素块装饰条 -->
        <div class="flex mb-4 overflow-hidden select-none" aria-hidden="true" style="font-family: monospace; line-height: 1; font-size: 14px; letter-spacing: 0; color: var(--color-accent); opacity: 0.6;">
          {Array.from({ length: 50 }).map(() => (<span>█</span>))}
        </div>

        <h1
          class="text-3xl sm:text-5xl lg:text-6xl font-black font-mono tracking-tight mb-4 transition-colors duration-300 hero-title"
          style="color: var(--color-text); line-height: 1.1;"
        >
          &gt; hello_world
        </h1>

        <div class="flex mb-6 overflow-hidden select-none" aria-hidden="true" style="font-family: monospace; line-height: 1; font-size: 14px; letter-spacing: 0; color: var(--color-accent); opacity: 0.6;">
          {Array.from({ length: 50 }).map(() => (<span>█</span>))}
        </div>

        <!-- 终端提示符 -->
        <div class="font-mono text-sm sm:text-base leading-relaxed">
          <div class="flex flex-wrap items-baseline gap-x-2">
            <span style="color: var(--color-accent);">user</span>
            <span style="color: var(--color-text-dim);">@</span>
            <span style="color: var(--color-accent);">my_blog</span>
            <span style="color: var(--color-text-muted);">:~$</span>
          </div>
          <div class="mt-1 ml-4" style="color: var(--color-text-dim);">
            &gt; <span style="color: var(--color-accent);">就是现在</span><span class="cursor-blink"></span>
          </div>
          <div class="mt-3 ml-4" style="color: var(--color-text-muted);">
            <span style="color: var(--color-text-muted); opacity: 0.6;">//</span> 一个分享技术、阅读与生活的个人博客。
          </div>
          <div style="color: var(--color-text-muted); margin-left: 1rem;">
            <span style="color: var(--color-text-muted); opacity: 0.6;">//</span> by <span style="color: var(--color-accent);">lefomo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       ABOUT — 删除线幽默
       ============================================================ -->
  <section class="mb-20" id="about">
    <h2 class="text-lg font-black font-mono mb-6 transition-colors duration-300" style="color: var(--color-text);">
      <span style="color: var(--color-accent);">##</span> About Me
    </h2>

    <div class="font-mono text-sm leading-relaxed space-y-2 max-w-2xl transition-colors duration-300" style="color: var(--color-text-dim);">
      <p style="color: var(--color-text-dim); line-height: 1.8;">
        当我发现我越来越记不住我的技术和想法时，我用手机的备忘录进行记录，但内容量相当有限，而且我无法在其他设备随时访问到我的备忘录里的内容，所以做了这个博客。
      </p>
      <p class="mt-3">
        <span style="color: var(--color-text-muted); opacity: 0.6;">//</span> 博客目前共有 <span style="color: var(--color-accent);">{allPosts.length}</span> 篇文章、<span style="color: var(--color-accent);">{tags.length}</span> 个标签。
      </p>
    </div>
  </section>

  <!-- ============================================================
       POSTS — 博客文章
       ============================================================ -->
  <section class="mb-20" id="posts">
    <h2 class="text-lg font-black font-mono mb-6 transition-colors duration-300" style="color: var(--color-text);">
      <span style="color: var(--color-accent);">##</span> Posts
    </h2>

    {
      allPosts.length === 0 ? (
        <div class="p-12 text-center text-sm font-mono" style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-muted);">
          <span style="color: var(--color-text-muted); opacity: 0.6;">//</span> 还没有文章，敬请期待。
        </div>
      ) : (
        <div class="space-y-4">
          {allPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date.toISOString().slice(0, 10)}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
      )
    }
  </section>

  <!-- ============================================================
       TAGS — 标签云
       ============================================================ -->
  <section class="mb-20" id="tags-section">
    <h2 class="text-lg font-black font-mono mb-6 transition-colors duration-300" style="color: var(--color-text);">
      <span style="color: var(--color-accent);">##</span> Tags
    </h2>

    {
      tags.length === 0 ? (
        <p class="text-xs font-mono" style="color: var(--color-text-muted);"><span style="opacity: 0.6;">//</span> no tags yet</p>
      ) : (
        <div class="flex flex-wrap gap-2">
          {tags.map(([tag, count]) => (
            <a
              href={`${base}/tags/${encodeURIComponent(tag)}/`}
              class="text-xs font-mono px-2.5 py-1 rounded-lg transition-all duration-300"
              style="
                background: var(--color-surface);
                border: 1px solid var(--color-border);
                color: var(--color-tag-text);
              "
              onmouseenter="this.style.color='var(--color-accent)';this.style.borderColor='var(--color-accent-glow)';this.style.transform='translateY(-1px)';this.style.boxShadow='0 2px 8px var(--color-accent-glow-soft)'"
              onmouseleave="this.style.color='var(--color-tag-text)';this.style.borderColor='var(--color-border)';this.style.transform='translateY(0)';this.style.boxShadow='none'"
            >
              <span style="color: var(--color-accent);">#</span>{tag} <span style="color: var(--color-text-muted);">({count})</span>
            </a>
          ))}
        </div>
      )
    }

    <div class="mt-4">
      <a href={`${base}/tags/`} class="text-xs font-mono transition-colors duration-300" style="color: var(--color-accent);">
        <span style="color: var(--color-text-muted); opacity: 0.6;">//</span> view all tags →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* 像素头像动效 */
  .avatar-container {
    display: inline-block;
    cursor: pointer;
  }

  .avatar-img {
    animation: avatar-float 4s ease-in-out infinite;
  }

  .avatar-container:hover .avatar-img {
    transform: scale(1.06) rotate(-3deg);
    box-shadow:
      0 0 0 2px var(--color-bg),
      0 0 0 5px var(--color-accent),
      0 0 32px var(--color-accent-glow),
      0 0 64px var(--color-accent-glow-soft) !important;
    filter: contrast(1.2) saturate(1.5) brightness(1.05) !important;
    animation-play-state: paused;
  }

  .avatar-container:active .avatar-img {
    transform: scale(0.96) rotate(0deg);
    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes avatar-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* 标题动效 — 像素闪烁 + 色相偏移 */
  .hero-title {
    animation: title-glitch 4s ease-in-out infinite;
    position: relative;
  }

  .hero-title::after {
    content: "_";
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes title-glitch {
    0%, 90%, 100% {
      text-shadow:
        2px 2px 0 var(--color-accent-glow),
        -2px -2px 0 var(--color-accent-glow-soft);
      transform: translateX(0);
    }
    92% {
      text-shadow:
        -3px 0 0 var(--color-accent),
        3px 0 0 var(--color-accent-glow);
      transform: translateX(-2px);
    }
    94% {
      text-shadow:
        3px 0 0 var(--color-accent),
        -3px 0 0 var(--color-accent-glow);
      transform: translateX(2px);
    }
    96% {
      text-shadow:
        0 0 0 transparent;
      transform: translateX(0);
    }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
