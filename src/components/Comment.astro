---
// Comment.astro — 本地评论系统 (localStorage)，即刻可用，无需任何配置
export interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<div class="mt-12 max-w-3xl mx-auto" id="comment-section" data-slug={slug}>
  <h2 class="text-sm font-bold uppercase tracking-[0.2em] mb-6 font-mono flex items-center gap-2 transition-colors duration-300" style="color: var(--color-accent);">
    <span class="inline-block w-2 h-2" style="background: var(--color-accent); box-shadow: 0 0 6px var(--color-accent-glow);"></span>
    comments
  </h2>

  <!-- 评论输入区 -->
  <div
    class="p-5 mb-4 transition-colors duration-300"
    style="
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      clip-path: polygon(0 6px, 3px 3px, 6px 0, calc(100% - 6px) 0, calc(100% - 3px) 3px, 100% 6px,
                          100% calc(100% - 6px), calc(100% - 3px) calc(100% - 3px),
                          calc(100% - 6px) 100%, 6px 100%, 3px calc(100% - 3px), 0 calc(100% - 6px));
    "
  >
    <div class="flex items-center gap-2 mb-3 text-xs font-mono" style="color: var(--color-accent);">
      <span>&gt;</span><span>write_comment</span><span class="cursor-blink"></span>
    </div>

    <input
      type="text"
      id="comment-name"
      placeholder="昵称 (可选)"
      maxlength="30"
      class="w-full mb-2 px-3 py-2 text-sm font-mono transition-colors duration-300 focus:outline-none"
      style="
        background: var(--color-surface-alt);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        clip-path: polygon(0 2px, 2px 0, calc(100% - 2px) 0, 100% 2px, 100% calc(100% - 2px), calc(100% - 2px) 100%, 2px 100%, 0 calc(100% - 2px));
      "
      onfocus="this.style.borderColor='var(--color-accent-glow)'"
      onblur="this.style.borderColor='var(--color-border)'"
    />

    <textarea
      id="comment-text"
      placeholder="输入评论... (Ctrl+Enter 提交)"
      rows="3"
      maxlength="1000"
      class="w-full mb-3 px-3 py-2 text-sm font-mono resize-none transition-colors duration-300 focus:outline-none"
      style="
        background: var(--color-surface-alt);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        clip-path: polygon(0 2px, 2px 0, calc(100% - 2px) 0, 100% 2px, 100% calc(100% - 2px), calc(100% - 2px) 100%, 2px 100%, 0 calc(100% - 2px));
      "
      onfocus="this.style.borderColor='var(--color-accent-glow)'"
      onblur="this.style.borderColor='var(--color-border)'"
    ></textarea>

    <div class="flex items-center justify-between">
      <button
        id="comment-submit"
        class="px-4 py-1.5 text-xs font-mono transition-colors duration-300 cursor-pointer hover:opacity-80"
        style="
          background: var(--color-accent);
          color: var(--color-bg);
          border: none;
          font-weight: 700;
          clip-path: polygon(0 2px, 2px 0, calc(100% - 2px) 0, 100% 2px, 100% calc(100% - 2px), calc(100% - 2px) 100%, 2px 100%, 0 calc(100% - 2px));
        "
      >
        submit
      </button>
      <span id="comment-hint" class="text-xs font-mono" style="color: var(--color-text-muted);"></span>
    </div>
  </div>

  <!-- 评论列表 -->
  <div id="comment-list" class="space-y-3"></div>
</div>

<script>
  // 从 data-slug 读取文章标识
  function initComments() {
    const section = document.getElementById('comment-section');
    if (!section || section.dataset.commentReady) return;
    section.dataset.commentReady = '1';

    const slug = section.dataset.slug || 'unknown';
    const storageKey = 'blog_comments_' + slug;

    interface Comment {
      id: string;
      name: string;
      text: string;
      time: string;
    }

    function getComments(): Comment[] {
      try { return JSON.parse(localStorage.getItem(storageKey) || '[]'); }
      catch { return []; }
    }

    function saveComments(list: Comment[]) {
      localStorage.setItem(storageKey, JSON.stringify(list));
    }

    function esc(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function renderComments() {
      const list = getComments();
      const container = document.getElementById('comment-list');
      if (!container) return;

      if (list.length === 0) {
        container.innerHTML = `<p class="text-xs font-mono py-4" style="color: var(--color-text-muted);">&gt; no_comments_yet &mdash; be the first!</p>`;
        return;
      }

      container.innerHTML = list.map(c => `
        <div style="
          background: var(--color-surface);
          border: 1px solid var(--color-border);
          padding: 14px 18px;
          clip-path: polygon(0 4px, 2px 2px, 4px 0, calc(100% - 4px) 0, calc(100% - 2px) 2px, 100% 4px,
                              100% calc(100% - 4px), calc(100% - 2px) calc(100% - 2px),
                              calc(100% - 4px) 100%, 4px 100%, 2px calc(100% - 2px), 0 calc(100% - 4px));
        ">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px;">
            <span class="text-xs font-bold font-mono" style="color: var(--color-accent);">${esc(c.name || 'anonymous')}</span>
            <span class="text-xs font-mono" style="color: var(--color-text-muted);">${esc(c.time)}</span>
          </div>
          <p class="text-sm m-0 font-mono" style="color: var(--color-text-dim);white-space:pre-wrap;line-height:1.6;">${esc(c.text)}</p>
        </div>
      `).join('');
    }

    function handleSubmit() {
      const nameInput = document.getElementById('comment-name') as HTMLInputElement;
      const textInput = document.getElementById('comment-text') as HTMLTextAreaElement;
      const hint = document.getElementById('comment-hint');
      const text = textInput?.value.trim();

      if (!text) {
        if (hint) { hint.textContent = '> 请输入内容'; hint.style.color = '#ff6b6b'; }
        return;
      }
      if (text.length < 2) {
        if (hint) { hint.textContent = '> 至少2个字符'; hint.style.color = '#ff6b6b'; }
        return;
      }

      const comments = getComments();
      comments.unshift({
        id: Date.now().toString(36) + Math.random().toString(36).slice(2, 6),
        name: (nameInput?.value?.trim() || 'anonymous'),
        text: text,
        time: new Date().toISOString().slice(0, 16).replace('T', ' '),
      });

      if (comments.length > 200) comments.length = 200;
      saveComments(comments);
      textInput.value = '';
      if (hint) { hint.textContent = '> sent!'; hint.style.color = 'var(--color-accent)'; }
      setTimeout(() => { if (hint) { hint.textContent = ''; hint.style.color = ''; } }, 2000);

      renderComments();
    }

    // 绑定事件
    document.getElementById('comment-submit')?.addEventListener('click', handleSubmit);
    document.getElementById('comment-text')?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).ctrlKey && (e as KeyboardEvent).key === 'Enter') handleSubmit();
    });

    renderComments();
  }

  // Astro 页面加载后初始化
  document.addEventListener('astro:page-load', initComments);
  document.addEventListener('astro:after-swap', initComments);
  // 首次 DOM 就绪也触发
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initComments);
  } else {
    initComments();
  }
</script>
