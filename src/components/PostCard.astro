---
import { SITE } from "../consts";

interface Props {
  title: string;
  description: string;
  date: string;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;
const base = SITE.base;
---

<article
  class="group glow-hover transition-all duration-300"
  style="
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    clip-path: polygon(
      0 6px, 3px 3px, 6px 0,
      calc(100% - 6px) 0, calc(100% - 3px) 3px, 100% 6px,
      100% calc(100% - 6px), calc(100% - 3px) calc(100% - 3px),
      calc(100% - 6px) 100%,
      6px 100%, 3px calc(100% - 3px), 0 calc(100% - 6px)
    );
  "
>
  <div class="p-5">
    <!-- 终端风格元信息 -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-2 text-xs font-mono" style="color: var(--color-text-muted);">
      <span style="color: var(--color-text-muted); opacity: 0.6;">//</span>
      <time datetime={date}>{date}</time>
      {
        tags.length > 0 && (
          <span>
            <span style="color: var(--color-accent);">#</span>{tags.length} tag{tags.length > 1 ? "s" : ""}
          </span>
        )
      }
    </div>

    <!-- 标题 -->
    <h2 class="mb-2 font-mono">
      <a
        href={`${base}/blog/${slug}/`}
        class="text-base font-bold transition-colors duration-300"
        style="color: var(--color-text);"
      >
        {title}
      </a>
    </h2>

    <!-- 描述 -->
    <p class="text-sm leading-relaxed mb-3 line-clamp-2 font-mono" style="color: var(--color-text-muted);">
      {description}
    </p>

    <!-- 标签 -->
    {
      tags.length > 0 && (
        <div class="flex flex-wrap items-center gap-1.5">
          {tags.map((tag) => (
            <a
              href={`${base}/tags/${encodeURIComponent(tag)}/`}
              class="inline-flex items-center gap-1 text-xs font-mono px-2.5 py-1 rounded-lg transition-all duration-300"
              style="
                color: var(--color-text-muted);
                background: var(--color-surface-alt);
                border: 1px solid var(--color-border);
              "
              onmouseenter="this.style.color='var(--color-accent)';this.style.borderColor='var(--color-accent-glow)';this.style.transform='translateY(-1px)';this.style.boxShadow='0 2px 8px var(--color-accent-glow-soft)'"
              onmouseleave="this.style.color='var(--color-text-muted)';this.style.borderColor='var(--color-border)';this.style.transform='translateY(0)';this.style.boxShadow='none'"
            >
              <span style="color: var(--color-accent);">#</span>{tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .group:hover h2 a { color: var(--color-accent) !important; }
</style>
