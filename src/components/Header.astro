---
import { SITE } from "../consts";
---

<header
  id="site-header"
  class="sticky top-0 z-50 backdrop-blur-md transition-all duration-300"
  style="background: var(--color-header-bg); border-bottom: 2px solid var(--color-header-border); box-shadow: 0 1px 0 var(--color-header-shadow);"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-[72px] flex items-center justify-between">
    <!-- Logo / 终端提示符风格 -->
    <a
      href={SITE.base ? `${SITE.base}/` : "/"}
      class="flex items-center gap-3 group"
    >
      <img
        src={`${SITE.base}/avatar.jpeg`}
        alt="avatar"
        class="inline-block w-10 h-10 flex-shrink-0 pixelated transition-shadow duration-300"
        style="
          object-fit: cover;
          filter: contrast(1.15) saturate(1.3) brightness(0.95);
          border: 2px solid var(--color-accent);
          box-shadow: 0 0 0 1.5px var(--color-bg), 0 0 0 4px var(--color-accent), 0 0 8px var(--color-accent-glow);
          clip-path: polygon(
            0 4px, 2px 2px, 4px 0,
            calc(100% - 4px) 0, calc(100% - 2px) 2px, 100% 4px,
            100% calc(100% - 4px), calc(100% - 2px) calc(100% - 2px),
            calc(100% - 4px) 100%,
            4px 100%, 2px calc(100% - 2px), 0 calc(100% - 4px)
          );
        "
      />
      <span class="text-lg font-bold tracking-tight font-mono transition-colors duration-300" style="color: var(--color-text);">
        user<span style="color: var(--color-accent);">@</span>my_blog<span style="color: var(--color-text-muted);">:~$</span>
      </span>
    </a>

    <!-- Nav -->
    <div class="flex items-center gap-1 sm:gap-2 text-sm font-medium font-mono">
      <a href={SITE.base ? `${SITE.base}/` : "/"}
         class="px-3 py-2 transition-colors duration-300" style="color: var(--color-text-muted);"
         onmouseenter="this.style.color='var(--color-accent)'" onmouseleave="this.style.color='var(--color-text-muted)'">
        Home
      </a>
      <a href={`${SITE.base}/#posts`}
         class="px-3 py-2 transition-colors duration-300" style="color: var(--color-text-muted);"
         onmouseenter="this.style.color='var(--color-accent)'" onmouseleave="this.style.color='var(--color-text-muted)'">
        Posts
      </a>
      <a href={`${SITE.base}/tags/`}
         class="px-3 py-2 transition-colors duration-300" style="color: var(--color-text-muted);"
         onmouseenter="this.style.color='var(--color-accent)'" onmouseleave="this.style.color='var(--color-text-muted)'">
        Tags
      </a>
      <a href={`${SITE.base}/search/`}
         class="px-3 py-2 transition-colors duration-300 flex items-center gap-1" style="color: var(--color-text-muted);"
         onmouseenter="this.style.color='var(--color-accent)'" onmouseleave="this.style.color='var(--color-text-muted)'">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        Search
      </a>
      <a href={`${SITE.base}/rss.xml`}
         class="px-3 py-2 transition-colors duration-300 flex items-center gap-1" title="RSS"
         style="color: var(--color-text-muted);"
         onmouseenter="this.style.color='var(--color-accent)'" onmouseleave="this.style.color='var(--color-text-muted)'">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66A9.9 9.9 0 0113.9 20h-2.83A7.07 7.07 0 004 12.93v-2.83z"/>
        </svg>
      </a>

      <!-- Theme toggle -->
      <label class="theme-toggle ml-2" title="Toggle theme">
        <input type="checkbox" id="theme-switch" />
        <span class="track"></span>
        <span class="thumb">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </span>
      </label>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-switch') as HTMLInputElement | null;
  if (toggle) {
    toggle.checked = document.documentElement.classList.contains('light');
    toggle.addEventListener('change', () => {
      if (toggle.checked) {
        document.documentElement.classList.add('light');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.remove('light');
        localStorage.setItem('theme', 'dark');
      }
    });
  }
</script>

<script>
  // 下滑隐藏 / 上滑显示
  let lastScroll = 0;
  const header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', () => {
      const now = window.scrollY;
      if (now <= 0) {
        header.style.transform = 'translateY(0)';
      } else if (now > lastScroll && now > 80) {
        header.style.transform = 'translateY(-100%)';
      } else if (now < lastScroll) {
        header.style.transform = 'translateY(0)';
      }
      lastScroll = now;
    }, { passive: true });
  }
</script>
